+    def _exo_extrinsic_cv(self, obs: dict) -> np.ndarray:
+        """Return the 3x4 world→exo_camera extrinsic matrix at this tick.
+
+        Training's NPZ points_3d are expressed in the exo camera's frame; our
+        eval-time deltas must use the SAME frame to avoid axis-sign mismatches
+        (e.g. lift = -Z cam but +Z world for a downward-looking exo).
+        """
+        params = obs.get("sensor_param_exo_camera_1")
+        if params is None or "extrinsic_cv" not in params:
+            # Fall back to identity (world-frame deltas). Warn loudly.
+            logger.warning(
+                "[PretrainedHybrid] obs has no sensor_param_exo_camera_1/extrinsic_cv; "
+                "emitting deltas in WORLD frame (axis signs will NOT match training). "
+                "Ensure CameraParameterSensor for 'exo_camera_1' is registered on this env."
+            )
+            identity = np.eye(4, dtype=np.float32)[:3]
+            return identity
+        return np.asarray(params["extrinsic_cv"], dtype=np.float32)
+
+    def _reached_handoff_phase(self, obs: dict) -> bool:
+        """Handoff triggers once the pickup object is 'held' by the gripper.
+        Reads ``obs['grasp_state_pickup_obj']['gripper']['held']`` which is
+        populated by the env's GraspStateSensor from actual MuJoCo contact
+        state — independent of any registered scripted planner's phase.
+        (``obs['policy_phase']`` is planner-based and returns -1 for our
+        learned-policy eval, so it's not usable here.)
+        """
+        gs = obs.get("grasp_state_pickup_obj")
+        if isinstance(gs, dict):
+            return bool(gs.get("gripper", {}).get("held", False))
+        return False
+
+    def _build_images_for_agent(
+        self, obs: dict, n_obs: int, obs_step_delta: int,
+        camera_names: list | None = None,
+    ) -> list:
+        cams = camera_names if camera_names is not None else self.camera_names
+        images = []
+        for cam_name in cams:
+            if cam_name == "exo_camera_1":
+                cam_name = "droid_shoulder_light_randomization" if "droid_shoulder_light_randomization" in obs else "exo_camera_1"
+            elif cam_name == "wrist_camera":
+                cam_name = "wrist_camera_zed_mini" if "wrist_camera_zed_mini" in obs else "wrist_camera"
+            if cam_name not in obs:
+                raise KeyError(f"Camera '{cam_name}' not in obs. Available: {list(obs.keys())}")
+            cam_images = []
+            if n_obs == 1:
+                cam_images.append(obs[cam_name])
+            else:
+                cur_len = len(self.obs_history)
+                if cur_len > 0:
+                    cur_step = cur_len - 1
+                    for i in range(n_obs):
+                        idx = cur_step - (n_obs - 1 - i) * obs_step_delta
+                        if 0 <= idx < cur_len:
+                            cam_images.append(self.obs_history[idx][cam_name])
+                assert cam_images, "No frames available in obs_history"
+            images.extend(cam_images)
+        return images
