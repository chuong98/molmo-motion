+def autodetect_traj3d_hyperparams(checkpoint: Optional[str]) -> dict:
+    """Parse P/H/F/prompt_style out of an init checkpoint's config.yaml.
+
+    Looks at ``data.kwargs_mixture[0].datasets[0].dataset_name`` which for our
+    molmo2 trajectory runs follows the grammar documented in
+    ``claude_tasks/molmo2-world-model/model_doc.md §6.2``:
+
+        trajectory_3d[_v1match][...]_p<P>_h<H>_f<F>
+
+    Missing fields are returned as None so the CLI override path can fill them
+    with hardcoded defaults. Swallows *any* parse error (returning all-None);
+    this helper is pure convenience — it never fails the training.
+    """
+    import re
+    import yaml
+
+    out = {"num_points": None, "history_size": None, "num_future_frames": None, "prompt_style": None}
+    if not checkpoint:
+        return out
+    cfg_path = os.path.join(checkpoint, "config.yaml")
+    if not os.path.exists(cfg_path):
+        return out
+    try:
+        with open(cfg_path) as f:
+            cfg = yaml.safe_load(f)
+        ds_name = ""
+        try:
+            ds_name = cfg["data"]["kwargs_mixture"][0]["datasets"][0]["dataset_name"]
+        except (KeyError, IndexError, TypeError):
+            pass
+        if not isinstance(ds_name, str) or not ds_name.startswith("trajectory_3d"):
+            return out
+        m = re.search(r"_p(\d+)_h(\d+)_f(\d+)", ds_name)
+        if m:
+            out["num_points"] = int(m.group(1))
+            out["history_size"] = int(m.group(2))
+            out["num_future_frames"] = int(m.group(3))
+        out["prompt_style"] = "v1_match" if "_v1match" in ds_name else "default"
+    except Exception:
+        pass
+    return out
+
