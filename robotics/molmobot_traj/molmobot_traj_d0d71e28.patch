+    def _populate_pretrained_buffer(self, obs: dict) -> None:
+        images = self._build_images_for_agent(
+            obs, self._pretrained_n_obs, self._pretrained_obs_step_delta,
+            camera_names=self._pretrained_camera_names,
+        )
+        robot_state = obs["robot_state"]
+        qpos_parts = []
+        for g in self.action_move_group_names:
+            if "gripper" not in g:
+                qpos_parts.append(robot_state["qpos"][g])
+            else:
+                qpos_parts.append(
+                    robot_state["qpos"][g][:self.config.policy_config.gripper_representation_count]
+                )
+        state = np.concatenate(qpos_parts).astype(np.float32)
+        goal = obs["task"] if "task" in obs else self.task.get_task_description()
+
+        pred_actions = self.pretrained_agent.get_action_chunk(
+            images=images, task_description=goal, state=state,
+        )
+
+        self.action_buffer = []
+        for t in range(pred_actions.shape[0]):
+            action = {}
+            start = 0
+            for group_name in self.action_move_group_names:
+                dim = self.action_spec[group_name]
+                sel = pred_actions[t, start:start + dim]
+                if "gripper" in group_name and self.config.policy_config.clamp_gripper:
+                    action[group_name] = np.where(sel > 128, 255, 0).astype(sel.dtype)
+                else:
+                    action[group_name] = pred_actions[t, start:start + dim]
+                start += dim
+            self.action_buffer.append(action)
+        self.buffer_index = 0
+
+    def _populate_action_buffer(self, observation) -> None:
+        """Parent builds + executes the action chunk via ActionExpert. For
+        Option B we additionally run an LM autoregressive decode on the SAME
+        prompt/images/state to capture the model's own predicted future
+        ``<tracks>``; those are stashed so the next query's history comes from
+        predictions (feedback loop) instead of the object-pose sensor."""
+        super()._populate_action_buffer(observation)
+        if not self._use_pred_feedback:
+            return
+
+        obs = observation[0] if isinstance(observation, list) else observation
+
+        # Rebuild the exact images/state/prompt that super() just used. The
+        # prompt rebuild is idempotent: _build_joint_mode_prompt reads the
+        # same _last_predicted_delta_mm / _last_pred_anchor_cam_pt as super()
+        # did, so it returns the same text and re-stashes the same
+        # _current_query_anchor_cam_pt.
+        images = self._build_images_for_agent(
+            obs, self.input_window_size, self.obs_step_delta,
+            camera_names=self.camera_names,
+        )
+        robot_state = obs["robot_state"]
+        qpos_parts = []
+        for g in self.action_move_group_names:
+            if "gripper" not in g:
+                qpos_parts.append(robot_state["qpos"][g])
+            else:
+                qpos_parts.append(
+                    robot_state["qpos"][g][:self.config.policy_config.gripper_representation_count]
+                )
+        state = np.concatenate(qpos_parts).astype(np.float32)
+        goal = obs["task"] if "task" in obs else self.task.get_task_description()
+        if self._emit_real_history:
+            prompt_text = self._build_joint_mode_prompt(obs, goal)
+        else:
+            prompt_text = goal
+
+        delta_mm = self._decode_predicted_tracks(prompt_text, images, state)
+        if delta_mm is None:
+            logger.warning(
+                "[PretrainedHybrid] LM decode returned None; feedback history "
+                "will reuse last successful prediction (may drift)."
+            )
+            return
+        if self._current_query_anchor_cam_pt is None:
+            logger.warning(
+                "[PretrainedHybrid] _current_query_anchor_cam_pt unset after "
+                "prompt build; skipping feedback-history update."
+            )
+            return
+        self._last_predicted_delta_mm = delta_mm
+        self._last_pred_anchor_cam_pt = self._current_query_anchor_cam_pt.copy()
+        # Small log so we can sanity-check feedback is firing.
+        mags = np.linalg.norm(delta_mm.astype(np.float32).reshape(-1, 3), axis=1)
+        logger.info(
+            f"[PretrainedHybrid][feedback] decoded LM tracks "
+            f"(F={delta_mm.shape[0]},P={delta_mm.shape[1]}) "
+            f"|Δ| mean={mags.mean():.1f}mm max={mags.max():.1f}mm"
+        )
+
+    def _decode_predicted_tracks(self, prompt_text: str, images: list, state: np.ndarray) -> np.ndarray | None:
+        """Run LM autoregressive decode to get Job B's predicted ``<tracks>``
+        answer. Parse it into (F, P, 3) int-mm deltas (in exo-cam frame,
+        relative to the anchor at prediction time).
+
+        Returns None if decode or parse fails."""
+        import re as _re
+        import torch as _torch
+        try:
+            example = {
+                "style": "demo",
+                "question": prompt_text,
+                "image": images if len(images) > 1 else images[0],
+            }
+            if state is not None:
+                example["state"] = state
+            processed = self.agent.preprocessor(example)
+            batch = self.agent.collator([processed])
+            from olmo.torch_util import move_to_device
+            batch = move_to_device(batch, self.agent.device)
+            # MolmoBot.forward now absorbs **extra_kwargs so VideoOlmo.generate
+            # can pass through the image-args superset (num_images,
+            # multimodal_type, num_image_starts) without hitting an unexpected-
+            # kwarg TypeError. No wrapping needed.
+            with _torch.no_grad():
+                with _torch.autocast(device_type="cuda", dtype=_torch.bfloat16):
+                    olmo_gen = self.agent.model.generate(
+                        batch=batch, max_steps=1200, beam_size=1, is_distributed=False,
+                    )
+            ids = olmo_gen.token_ids[0, 0].detach().cpu().numpy()
+            # VideoOlmo exposes ``build_tokenizer`` on the CONFIG, not the model.
+            tokenizer = self.agent.model.config.build_tokenizer()
+            pred_text = tokenizer.decode(ids[ids >= 0].tolist())
+            # Primary pattern: full well-formed <tracks …>3d object trajectories</tracks>.
+            # Second: closed attr but no closing tag.
+            # Last:  unclosed attr (generation was cut off by max_steps) — parse
+            #        whatever complete frames are there.
+            m = _re.search(r'<tracks coords="([^"]*)">3d object trajectories</tracks>', pred_text)
+            if m is None:
+                m = _re.search(r'<tracks coords="([^"]*)"', pred_text)
+            if m is None:
+                m = _re.search(r'<tracks coords="(.*)$', pred_text, _re.DOTALL)
+            if m is None:
+                preview_head = pred_text[:200].replace("\n", " ")
+                preview_tail = pred_text[-200:].replace("\n", " ")
+                logger.warning(
+                    f"[PretrainedHybrid] LM tracks prediction missing or malformed. "
+                    f"len={len(pred_text)} head={preview_head!r} tail={preview_tail!r}"
+                )
+                return None
+            F, P = self._eval_F, self._eval_P
+            out = np.zeros((F, P, 3), dtype=np.float32)
+            for fi, frame_s in enumerate(m.group(1).split(";")[:F]):
+                toks = frame_s.split()
+                i = 1
+                while i + 3 < len(toks):
+                    try:
+                        pidx = int(toks[i]); dx = int(toks[i+1]); dy = int(toks[i+2]); dz = int(toks[i+3])
+                    except ValueError:
+                        break
+                    if 1 <= pidx <= P:
+                        out[fi, pidx - 1] = [dx, dy, dz]
+                    i += 4
+            return out  # int-mm in cam frame, relative to anchor at prediction time
+        except Exception as exc:
+            logger.warning(f"[PretrainedHybrid] LM decode failed: {exc}")
+            return None
+
+    def inference_model(self, model_input) -> dict[str, np.ndarray]:
+        obs = model_input[0] if isinstance(model_input, list) else model_input
+        self.obs_history.append(obs)
+
+        reached = self._reached_handoff_phase(obs)
+        if reached and self._first_handoff_phase_step is None:
+            self._first_handoff_phase_step = self.step_count
+            logger.info(
+                f"[PretrainedHybrid] handoff phase reached (policy_phase>="
+                f"{self._handoff_phase_threshold}) at step {self.step_count}"
+            )
+
+        if (reached and self._first_handoff_phase_step is not None
+                and not self._use_our_policy):
+            steps_since = self.step_count - self._first_handoff_phase_step
+            tick_count = steps_since // self.execute_horizon
+            if tick_count >= self._handoff_ticks:
+                self._use_our_policy = True
+                self.action_buffer = []
+                self.buffer_index = 0
+                logger.info(
+                    f"[PretrainedHybrid] HANDOFF at step {self.step_count} "
+                    f"(steps_since_phase5={steps_since}, tick={tick_count+1})"
+                )
+
+        if self.buffer_index >= self.execute_horizon or not self.action_buffer:
+            if self._use_our_policy:
+                self._populate_action_buffer(model_input)
+            else:
+                self._populate_pretrained_buffer(obs)
+
+        action = self.action_buffer[self.buffer_index]
+        self.buffer_index += 1
+        self.step_count += 1
+
+        if self.action_type == "joint_pos_rel":
+            pd = action["arm"][:7]
+            rel = np.abs(pd) / self.relative_max_joint_delta
+            if np.max(rel) > 1:
+                action["arm"][:7] = pd / np.max(rel)
+        else:
+            pd = action["arm"][:7] - obs["robot_state"]["qpos"]["arm"]
+            rel = np.abs(pd) / self.relative_max_joint_delta
+            if np.max(rel) > 1:
+                action["arm"][:7] = obs["robot_state"]["qpos"]["arm"] + pd / np.max(rel)
+        return action
+
